{
  "include": [
    "client/src/main.tsx",
    "shared/**/*",
    "server/_core/index.ts",
    "server/routers.ts",
    "server/db.ts",
    "server/storage.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "drizzle.config.ts"
  ],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts", "client/src/pages/ComponentShowcase.tsx"],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}
